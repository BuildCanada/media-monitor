# PostgreSQL connection string
# Local: postgresql://youruser@localhost:5432/media_monitor
# DevContainer: postgresql://postgres:postgres@db:5432/media_monitor
DATABASE_URL=postgresql://youruser@localhost:5432/media_monitor

# Turbopuffer API key (get from https://turbopuffer.com/dashboard)
TURBOPUFFER_API_KEY=
# Turbopuffer namespace (unique per environment to isolate dev/prod data)
TURBOPUFFER_NAMESPACE=
